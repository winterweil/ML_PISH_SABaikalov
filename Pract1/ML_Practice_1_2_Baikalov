\n","\n","skew_sorted = skew_values.sort_values(ascending=False)\n","\n","skew_sorted.head(3)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":178},"id":"usfXpG7NzVsp","executionInfo":{"status":"ok","timestamp":1771860848700,"user_tz":-420,"elapsed":258,"user":{"displayName":"Сергей «wlamb» Байкалов","userId":"08061695704779150087"}},"outputId":"7116ccaa-23c7-42a6-f622-05e8f7afebc8"},"execution_count":null,"outputs":[{"output_type":"execute_result","data":{"text/plain":["magnesium          1.098191\n","malic_acid         1.039651\n","color_intensity    0.868585\n","dtype: float64"],"text/html":["<div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"dataframe\">\n","  <thead>\n","    <tr style=\"text-align: right;\">\n","      <th></th>\n","      <th>0</th>\n","    </tr>\n","  </thead>\n","  <tbody>\n","    <tr>\n","      <th>magnesium</th>\n","      <td>1.098191</td>\n","    </tr>\n","    <tr>\n","      <th>malic_acid</th>\n","      <td>1.039651</td>\n","    </tr>\n","    <tr>\n","      <th>color_intensity</th>\n","      <td>0.868585</td>\n","    </tr>\n","  </tbody>\n","</table>\n","</div><br><label><b>dtype:</b> float64</label>"]},"metadata":{},"execution_count":33}]},{"cell_type":"markdown","source":["Задание 3. Создание «идеального» разделяющего признака\n","Сконструируйте новый признак как линейную комбинацию двух существующих:\n","wine_quality_index = 0.6 * df['flavanoids'] + 0.4 * df['color_intensity']\n","\n","Постройте график распределения этого индекса по регионам. Улучшает ли он разделение классов по сравнению с исходными признаками? Подтвердите вывод количественно через расчёт коэффициента разделения классов (разница средних / сумма стандартных отклонений).\n","\n","Ответ: WQI лучше разделяет Region_1 и Region_2, чем оба исходных признака по отдельности, однако для пары Region_1 vs Region_3 признак flavanoids превосходит WQI.\n","Это объясняется тем, что color_intensity у Region_1 и Region_3 схожа, а flavanoids — разные."],"metadata":{"id":"0c3tlJxLK0F4"}},{"cell_type":"code","source":["df_wine['wine_quality_index'] = 0.6 * df_wine['flavanoids'] + 0.4 * df_wine['color_intensity']\n","\n","def class_separation(df, feature, class_col, c1, c2):\n","    \"\"\"Разница средних / сумма стандартных отклонений\"\"\"\n","    g1 = df[df[class_col] == c1][feature]\n","    g2 = df[df[class_col] == c2][feature]\n","    return abs(g1.mean() - g2.mean()) / (g1.std() + g2.std())\n","\n","regions = ['Region_1', 'Region_2', 'Region_3']\n","features_to_compare = ['wine_quality_index', 'flavanoids', 'color_intensity']\n","region_pairs = [('Region_1','Region_2'), ('Region_1','Region_3'), ('Region_2','Region_3')]\n","\n","print(\"Коэффициент разделения классов:\")\n","print(f\"{'Пара классов':<25} {'WQI':>8} {'flavanoids':>12} {'color_int':>12}\")\n","print(\"-\" * 60)\n","for r1, r2 in region_pairs:\n","    seps = [class_separation(df_wine, f, 'region', r1, r2) for f in features_to_compare]\n","    best = features_to_compare[seps.index(max(seps))]\n","    print(f\"  {r1} vs {r2}:   {seps[0]:>6.3f}   {seps[1]:>10.3f}   {seps[2]:>10.3f}   ← лучший: {best}\")\n","\n","print(\"\\nСтатистика wine_quality_index по регионам:\")\n","print(df_wine.groupby('region')['wine_quality_index'].describe().round(3))\n","\n","region_palette = {'Region_1': '#4CAF50', 'Region_2': '#2196F3', 'Region_3': '#FF5722'}\n","\n","fig, axes = plt.subplots(1, 1, figsize=(6, 5)) # Changed to 1, 1 for a single plot\n","\n","# Гистограммы по регионам\n","for region, color in region_palette.items():\n","    data = df_wine[df_wine['region'] == region]['wine_quality_index']\n","    axes.hist(data, bins=15, alpha=0.6, color=color, label=region, edgecolor='white')\n","    axes.axvline(data.mean(), color=color, linewidth=2.5, linestyle='--')\n","axes.set_xlabel('wine_quality_index')\n","axes.set_ylabel('Частота')\n","axes.set_title('Распределение WQI по регионам\\n(пунктиры = средние)', fontweight='bold')\n","axes.legend()\n","axes.grid(True, alpha=0.3)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":734},"id":"ypwUyEPczYyP","executionInfo":{"status":"ok","timestamp":1771861621787,"user_tz":-420,"elapsed":2741,"user":{"displayName":"Сергей «wlamb» Байкалов","userId":"08061695704779150087"}},"outputId":"c41041a9-a007-4bbb-d059-f5d7c940bfff"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Коэффициент разделения классов:\n","Пара классов                   WQI   flavanoids    color_int\n","------------------------------------------------------------\n","  Region_1 vs Region_2:    1.124        0.817        1.129   ← лучший: color_intensity\n","  Region_1 vs Region_3:    0.339        3.185        0.526   ← лучший: flavanoids\n","  Region_2 vs Region_3:    0.568        1.300        1.332   ← лучший: color_intensity\n","\n","Статистика wine_quality_index по регионам:\n","          count   mean    std    min    25%    50%    75%    max\n","region                                                          \n","Region_1   59.0  4.001  0.691  2.894  3.428  3.896  4.369  5.838\n","Region_2   71.0  2.483  0.659  1.122  2.084  2.402  2.711  5.448\n","Region_3   48.0  3.427  1.002  1.822  2.538  3.417  4.162  5.986\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 600x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]}]}