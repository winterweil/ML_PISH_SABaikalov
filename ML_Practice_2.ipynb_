{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[{"file_id":"1NwtLZqmiyDpVQbjTBoN4x3wn4rG_yFaz","timestamp":1772476604157}],"authorship_tag":"ABX9TyOAuoIs8BPqKZc8+DZnu4TJ"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"markdown","source":["# Практическое занятие №2 — Исследовательский анализ данных (EDA) и визуализация зависимостей / Байкалов Сергей Андреевич"],"metadata":{"id":"GeB3Z8H2xbMR"}},{"cell_type":"markdown","source":["### Задание 1: Сравнение стратегий импутации (или обработки)\n","**Цель:** Оценить влияние метода обработки данных на статистику признака."],"metadata":{"id":"AfaJgRe3xxpj"}},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"s3UjhwUWw61Y","executionInfo":{"status":"ok","timestamp":1772476350543,"user_tz":-420,"elapsed":1833,"user":{"displayName":"Сергей «wlamb» Байкалов","userId":"08061695704779150087"}},"outputId":"7e45e3ba-c6c7-47a6-b9fe-0492dfefbc62"},"outputs":[{"output_type":"stream","name":"stdout","text":["Количество пропусков: 1018\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Исходные данные\n","Mean: 5.428999742190376\n","Std: 2.4741731394243205\n","\n","После Mean\n","Mean: 5.431698145402711\n","Std: 2.4436983592275086\n","\n","После Median\n","Mean: 5.421779772203083\n","Std: 2.4440863178071885\n"]}],"source":["from sklearn.datasets import fetch_california_housing\n","import pandas as pd\n","import numpy as np\n","import matplotlib.pyplot as plt\n","import seaborn as sns\n","\n","# Загрузка данных\n","data = fetch_california_housing()\n","df = pd.DataFrame(data.data, columns=data.feature_names)\n","df['Target'] = data.target\n","\n","original = df['AveRooms'].copy()\n","\n","np.random.seed(42)\n","mask = np.random.choice([True, False], size=len(df), p=[0.05, 0.95])\n","df.loc[mask, 'AveRooms'] = np.nan\n","\n","print(\"Количество пропусков:\", df['AveRooms'].isna().sum())\n","\n","df_mean = df.copy()\n","df_median = df.copy()\n","\n","mean_value = df_mean['AveRooms'].mean()\n","df_mean['AveRooms'] = df_mean['AveRooms'].fillna(mean_value)\n","\n","median_value = df_median['AveRooms'].median()\n","df_median['AveRooms'] = df_median['AveRooms'].fillna(median_value)\n","\n","plt.figure()\n","plt.hist(original, bins=40)\n","plt.title(\"Исходное распределение\")\n","plt.show()\n","\n","plt.figure()\n","plt.hist(df_mean['AveRooms'], bins=40)\n","plt.title(\"После заполнения средним\")\n","plt.show()\n","\n","plt.figure()\n","plt.hist(df_median['AveRooms'], bins=40)\n","plt.title(\"После заполнения медианой\")\n","plt.show()\n","\n","print(\"Исходные данные\")\n","print(\"Mean:\", original.mean())\n","print(\"Std:\", original.std())\n","\n","print(\"\\nПосле Mean\")\n","print(\"Mean:\", df_mean['AveRooms'].mean())\n","print(\"Std:\", df_mean['AveRooms'].std())\n","\n","print(\"\\nПосле Median\")\n","print(\"Mean:\", df_median['AveRooms'].mean())\n","print(\"Std:\", df_median['AveRooms'].std())"]},{"cell_type":"markdown","source":["При заполнении средним среднее почти не меняется.\n","\n","Стандартное отклонение уменьшается.\n","\n","При заполнении медианой среднее слегка смещается.\n","\n","Стандартное отклонение также уменьшается, но распределение сохраняется лучше при наличии выбросов."],"metadata":{"id":"HLYwpwfhyevP"}},{"cell_type":"markdown","source":["### Задание 2: Детекция и визуализация выбросов\n","**Цель:** Научиться находить и аргументированно удалять аномалии."],"metadata":{"id":"fwNMaNjkyp0S"}},{"cell_type":"code","source":["corr = df.corr(numeric_only=True)\n","print(corr['Target'].sort_values(ascending=False))\n","\n","Q1 = df['MedInc'].quantile(0.25)\n","Q3 = df['MedInc'].quantile(0.75)\n","IQR = Q3 - Q1\n","\n","lower = Q1 - 1.5 * IQR\n","upper = Q3 + 1.5 * IQR\n","\n","outliers_iqr = df[(df['MedInc'] < lower) | (df['MedInc'] > upper)]\n","\n","print(\"Количество выбросов IQR:\", len(outliers_iqr))\n","\n","z_scores = np.abs((df['MedInc'] - df['MedInc'].mean()) / df['MedInc'].std())\n","outliers_z = df[z_scores > 3]\n","\n","print(\"Количество выбросов Z-score:\", len(outliers_z))\n","\n","plt.figure()\n","plt.boxplot(df['MedInc'])\n","plt.title(\"Boxplot MedInc\")\n","plt.show()\n","\n","plt.figure()\n","\n","plt.scatter(df.index, df['MedInc'])\n","plt.scatter(outliers_iqr.index,\n","            outliers_iqr['MedInc'],\n","            color='red')\n","\n","plt.title(\"Scatter MedInc (IQR)\")\n","plt.show()\n","\n","plt.figure()\n","\n","plt.scatter(df.index, df['MedInc'])\n","plt.scatter(outliers_z.index,\n","            outliers_z['MedInc'],\n","            color='red')\n","\n","plt.title(\"Scatter MedInc (Z-score)\")\n","plt.show()\n","\n","percent_iqr = len(outliers_iqr) / len(df) * 100\n","percent_z = len(outliers_z) / len(df) * 100\n","\n","print(\"Процент выбросов IQR:\", percent_iqr)\n","print(\"Процент выбросов Z-score:\", percent_z)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"VVMy-YwyyuA6","executionInfo":{"status":"ok","timestamp":1772476356085,"user_tz":-420,"elapsed":2439,"user":{"displayName":"Сергей «wlamb» Байкалов","userId":"08061695704779150087"}},"outputId":"78b9681c-1b3c-45e9-a01a-9f3c46ab8a52"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Target        1.000000\n","MedInc        0.688075\n","AveRooms      0.150539\n","HouseAge      0.105623\n","AveOccup     -0.023737\n","Population   -0.024650\n","Longitude    -0.045967\n","AveBedrms    -0.046701\n","Latitude     -0.144160\n","Name: Target, dtype: float64\n","Количество выбросов IQR: 681\n","Количество выбросов Z-score: 345\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Процент выбросов IQR: 3.299418604651163\n","Процент выбросов Z-score: 1.6715116279069766\n"]}]},{"cell_type":"markdown","source":["### Задание 3: Инженерия признаков и проверка гипотезы\n","**Цель:** Создать новый признак и проверить его полезность."],"metadata":{"id":"CPkrMMMFyur4"}},{"cell_type":"code","source":["# Создание нового признака\n","df['RoomsPerPerson'] = df['AveRooms'] / df['Population']\n","\n","print(df[['AveRooms', 'Population', 'RoomsPerPerson']].head())\n","\n","corr_matrix = df.corr(numeric_only=True)\n","\n","plt.figure(figsize=(10,8))\n","sns.heatmap(corr_matrix, annot=False)\n","plt.title(\"Корреляционная матрица\")\n","plt.show()\n","\n","print(corr_matrix['Target'].sort_values(ascending=False))\n","\n","plt.figure()\n","plt.scatter(df['RoomsPerPerson'], df['Target'])\n","plt.xlabel(\"RoomsPerPerson\")\n","plt.ylabel(\"Target\")\n","plt.title(\"Зависимость Target от RoomsPerPerson\")\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"cl3NFdxUy_VX","executionInfo":{"status":"ok","timestamp":1772476478308,"user_tz":-420,"elapsed":2453,"user":{"displayName":"Сергей «wlamb» Байкалов","userId":"08061695704779150087"}},"outputId":"3db977b1-781b-4419-860e-a6529890bd62"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["   AveRooms  Population  RoomsPerPerson\n","0  6.984127       322.0        0.021690\n","1  6.238137      2401.0        0.002598\n","2  8.288136       496.0        0.016710\n","3  5.817352       558.0        0.010425\n","4  6.281853       565.0        0.011118\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x800 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Target            1.000000\n","MedInc            0.688075\n","AveRooms          0.150539\n","HouseAge          0.105623\n","RoomsPerPerson    0.012120\n","AveOccup         -0.023737\n","Population       -0.024650\n","Longitude        -0.045967\n","AveBedrms        -0.046701\n","Latitude         -0.144160\n","Name: Target, dtype: float64\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["С увеличением количества комнат на человека растёт стоимость жилья. Признак целесообразно включить в модель, так как он добавляет структурную информацию о плотности проживания и может повысить качество анализа."],"metadata":{"id":"hUGm5RCe1RTJ"}}]}